# Environment
.env
*.env

# Streamlit secrets (never commit)
.streamlit/secrets.toml

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
.uv/
dist/
*.egg-info/

# Uploads / temp files — never commit document content
uploads/
tmp/
*.pdf
*.tiff
*.tif

# Exception: sample/dummy data used for development is safe to commit
!data/samples/

# Logs — audit logs may contain hashes; keep out of repo
logs/
*.log

# OS
.DS_Store
Thumbs.db
nul

# SQLite databases (runtime data — not for version control)
data/*.db
*.db

# Generated output files (Excel/CSV templates — binary, not for version control)
output/

# Test screenshots
*.png

# Debug / ad-hoc check files
debug.txt
match_check.txt
pref_check.txt
site_check.txt
*.check.txt
